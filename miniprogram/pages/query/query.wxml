<view class="page-container">
  <view class="search-card">
    <input class="search-input" placeholder="🔍 输入货品名称、供应商或日期" bindinput="onSearch" />
  </view>

  <view class="table-card" wx:if="{{list.length}}">
    <scroll-view scroll-x class="table-scroll">
      <view class="table-header">
        <view class="cell head seq">序号</view>
        <view class="cell head name">货品名称</view>
        <view class="cell head supplier">供应商</view>
        <view class="cell head date">单据日期</view>
        <view class="cell head op">原图</view>
      </view>
      <view wx:for="{{list}}" wx:key="_id" class="table-row">
        <view class="cell seq">{{index + 1}}</view>
        <view class="cell name">{{item.goods_name}}</view>
        <view class="cell supplier">{{item.supplier}}</view>
        <view class="cell date">{{item.order_time}}</view>
        <view class="cell op">
          <button wx:if="{{item.img_path}}" size="mini" class="img-btn" bindtap="viewImage" data-id="{{item._id}}">查看</button>
          <text wx:else class="no-img">无</text>
        </view>
      </view>
    </scroll-view>
  </view>
  <view wx:else class="empty-tip">输入关键词开始搜索</view>
</view>
