<view class="page-container">
  <button class="button-primary" bindtap="chooseImage">📷 拍照/选图识别单据</button>
  <image wx:if="{{imagePath}}" src="{{imagePath}}" mode="widthFix" class="preview-img"/>

  <view class="info-card">
    <view class="info-item">
      <text class="label">供应商</text>
      <input class="info-input" placeholder="请输入供应商" value="{{supplier}}" bindinput="onSupplierInput"/>
    </view>
    <view class="info-item">
      <text class="label">单据日期</text>
      <picker mode="date" value="{{order_time}}" bindchange="onDateChange">
        <view class="info-input picker-value">{{order_time || '请选择日期'}}</view>
      </picker>
    </view>
  </view>

  <view class="table-card" wx:if="{{list.length}}">
    <scroll-view scroll-x class="table-scroll">
      <view class="table-header">
        <view class="cell head seq">序号</view>
        <view class="cell head name">货品名称</view>
        <view class="cell head supplier">供应商</view>
        <view class="cell head date">单据日期</view>
        <view class="cell head op">操作</view>
      </view>
      <view wx:for="{{list}}" wx:key="index" class="table-row">
        <view class="cell seq">{{index + 1}}</view>
        <view class="cell name"><input value="{{item.goods_name}}" data-index="{{index}}" bindinput="onNameInput"/></view>
        <view class="cell supplier">{{supplier}}</view>
        <view class="cell date">{{order_time}}</view>
        <view class="cell op">
          <button size="mini" class="del-btn" bindtap="deleteRow" data-index="{{index}}">删除</button>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="action-bar" wx:if="{{list.length}}">
    <button class="button-primary" bindtap="addRow">+ 添加一行</button>
    <button class="button-primary" bindtap="saveAll">💾 保存全部</button>
  </view>
</view>
