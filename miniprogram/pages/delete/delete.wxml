<view class="delete">
  <scroll-view scroll-x>
    <view class="table-header">
      <view class="cell head">选择</view>
      <view class="cell head">供应商</view>
      <view class="cell head">日期</view>
      <view class="cell head">名称</view>
      <view class="cell head">规格</view>
      <view class="cell head">数量</view>
    </view>
    <view wx:for="{{list}}" wx:key="_id" class="table-row">
      <view class="cell"><checkbox value="{{item._id}}" checked="{{item.checked}}" data-index="{{index}}" bindtap="toggle"/></view>
      <view class="cell">{{item.supplier}}</view>
      <view class="cell">{{item.order_time}}</view>
      <view class="cell">{{item.goods_name}}</view>
      <view class="cell">{{item.spec}}</view>
      <view class="cell">{{item.quantity}}</view>
    </view>
  </scroll-view>
  <button class="button-primary" bindtap="deleteSelected">🗑️ 删除所选</button>
</view>