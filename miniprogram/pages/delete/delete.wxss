.page-container { padding: var(--spacing-md); }
.table-card {
  background: var(--card-bg);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: var(--spacing-md);
}
.table-scroll { width: 100%; white-space: nowrap; }
.table-header, .table-row { display: flex; align-items: stretch; }
.cell {
  padding: 16rpx 10rpx;
  font-size: var(--font-sm);
  border-right: 1rpx solid var(--border);
  border-bottom: 1rpx solid var(--border);
  display: flex;
  align-items: center;
}
.cell.head {
  font-weight: 600;
  background: var(--primary-light);
  color: var(--primary);
  font-size: var(--font-md);
}
.seq { width: 80rpx; justify-content: center; }
.name { width: 320rpx; }
.supplier { width: 240rpx; }
.date { width: 220rpx; }
.sel { width: 120rpx; justify-content: center; border-right: none; }

.delete-action { margin-top: var(--spacing-md); }
.table-empty { text-align: center; padding: 40rpx; color: var(--text-secondary); font-size: var(--font-md); }
